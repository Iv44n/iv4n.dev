---
import { type CollectionEntry, getCollection, render } from 'astro:content'
import BlogPost from '#/layouts/BlogPost.astro'
import { SITE } from '#/config/site'
import { getBlogSlug, getLocalizedPath } from '#/i18n/utils'
import { defaultLang } from '#/i18n/ui'

interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props

const allPosts = await getCollection('blog')

const translations = allPosts
  .filter(p => p.data.id === post.data.id)
  .map(p => {
    const slug = getBlogSlug(p.id)
    return {
      lang: p.data.lang,
      href: getLocalizedPath(p.data.lang, `/blog/${slug}/`),
      title: p.data.title
    }
  })

// x-default points at the default-locale translation when it exists.
const defaultTranslation =
  translations.find(t => t.lang === defaultLang) ?? translations[0]
const alternateLinks = defaultTranslation
  ? [...translations, { ...defaultTranslation, lang: 'x-default' }]
  : translations

const slug = getBlogSlug(post.id)
const mdUrl = new URL(
  getLocalizedPath(post.data.lang, `/blog/${slug}.md`),
  Astro.site
).href
const githubUrl = `${SITE.repo.url}/blob/${SITE.repo.branch}/${post.filePath}`

const { Content } = await render(post)
---

<BlogPost
  {...post.data}
  alternateLinks={alternateLinks}
  isBlogPost={true}
  mdUrl={mdUrl}
  githubUrl={githubUrl}
>
  <Content />
</BlogPost>
