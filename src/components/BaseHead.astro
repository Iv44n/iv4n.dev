---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '#/styles/global.css'
import { SITE, SOCIALS, SKILLS } from '#/config/site'
import { getLangFromUrl } from '#/i18n/utils'
// Only the latin subset and the weights actually used by the UI. Importing the
// bare package would ship every subset and only weight 400, forcing the browser
// to synthesize the 500/600/700 used across headings (faux-bold).
import '@fontsource/geist-sans/latin-400.css'
import '@fontsource/geist-sans/latin-500.css'
import '@fontsource/geist-sans/latin-600.css'
import '@fontsource/geist-sans/latin-700.css'
import '@fontsource/jetbrains-mono/latin-400.css'
// Hashed URLs for the above-the-fold Geist weights, preloaded below so they are
// ready at first paint and don't cause a font-swap layout shift (CLS).
import geistSans400 from '@fontsource/geist-sans/files/geist-sans-latin-400-normal.woff2?url'
import geistSans500 from '@fontsource/geist-sans/files/geist-sans-latin-500-normal.woff2?url'
import geistSans600 from '@fontsource/geist-sans/files/geist-sans-latin-600-normal.woff2?url'
import geistSans700 from '@fontsource/geist-sans/files/geist-sans-latin-700-normal.woff2?url'

interface AlternateLink {
  lang: string
  href: string
}

interface Props {
  title: string
  description: string
  image?: string
  type?: 'website' | 'article'
  publishedTime?: Date
  updatedDate?: Date
  alternateLinks?: AlternateLink[]
}

const OG_LOCALES = { es: 'es_ES', en: 'en_US' } as const

const site = Astro.site ?? new URL('https://iv4n.dev')
const canonicalURL = new URL(Astro.url.pathname, site)
const lang = getLangFromUrl(Astro.url)

const {
  title,
  description,
  image = SITE.ogImage,
  type = 'website',
  publishedTime,
  updatedDate,
  alternateLinks
} = Astro.props

const imageURL = new URL(image, site).href
const ogLocale = OG_LOCALES[lang]
const altLocales = Object.entries(OG_LOCALES)
  .filter(([l]) => l !== lang)
  .map(([, locale]) => locale)

// Structured data (JSON-LD)
const personId = `${site.origin}/#person`
const websiteId = `${site.origin}/#website`

const person = {
  '@type': 'Person',
  '@id': personId,
  name: SITE.name,
  url: site.origin,
  image: new URL(SITE.ogImage, site).href,
  jobTitle: SITE.jobTitle[lang],
  email: `mailto:${SITE.email}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Lima',
    addressCountry: 'PE'
  },
  knowsAbout: [...SKILLS],
  sameAs: Object.values(SOCIALS)
}

const website = {
  '@type': 'WebSite',
  '@id': websiteId,
  url: site.origin,
  name: SITE.title,
  description: SITE.description,
  inLanguage: lang,
  author: { '@id': personId },
  publisher: { '@id': personId }
}

const graph: Record<string, unknown>[] = [person, website]

if (type === 'article') {
  graph.push({
    '@type': 'BlogPosting',
    headline: title,
    description,
    url: canonicalURL.href,
    mainEntityOfPage: canonicalURL.href,
    image: imageURL,
    inLanguage: lang,
    ...(publishedTime && { datePublished: publishedTime.toISOString() }),
    dateModified: (updatedDate ?? publishedTime)?.toISOString(),
    author: { '@id': personId },
    publisher: { '@id': personId }
  })
}

const jsonLd = { '@context': 'https://schema.org', '@graph': graph }
---

<!-- Global Metadata -->
<meta charset='utf-8' />
<script is:inline>
const theme = (() => {
  if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
    return localStorage.getItem('theme')
  }
  if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
    return 'dark'
  }
  return 'light'
})()

if (theme === 'light') {
  document.documentElement.classList.remove('dark')
} else {
  document.documentElement.classList.add('dark')
}
window.localStorage.setItem('theme', theme)
</script>
<meta name='viewport' content='width=device-width,initial-scale=1' />
<meta name='theme-color' media='(prefers-color-scheme: light)' content='#ffffff' />
<meta name='theme-color' media='(prefers-color-scheme: dark)' content='#0d0d0e' />
<meta name='color-scheme' content='light dark' />

<!-- Preload above-the-fold fonts to avoid a swap-induced layout shift (CLS) -->
<link rel='preload' as='font' type='font/woff2' crossorigin href={geistSans400} />
<link rel='preload' as='font' type='font/woff2' crossorigin href={geistSans700} />
<link rel='preload' as='font' type='font/woff2' crossorigin href={geistSans600} />
<link rel='preload' as='font' type='font/woff2' crossorigin href={geistSans500} />

<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
<link rel='apple-touch-icon' href='/apple-touch-icon.png' />
<link rel='sitemap' href='/sitemap-index.xml' />
<link
  rel='alternate'
  type='application/rss+xml'
  title={SITE.title}
  href={new URL('rss.xml', site)}
/>
<meta name='generator' content={Astro.generator} />

<!-- Canonical URL -->
<link rel='canonical' href={canonicalURL} />

<!-- Alternate Language Links -->
{alternateLinks?.map(({ lang: l, href }) => (
  <link rel='alternate' hreflang={l} href={new URL(href, site)} />
))}

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name='title' content={title} />
<meta name='description' content={description} />
<meta name='author' content={SITE.name} />
<meta name='robots' content='index, follow, max-image-preview:large, max-snippet:-1' />

<!-- Open Graph / Facebook -->
<meta property='og:type' content={type} />
<meta property='og:url' content={canonicalURL} />
<meta property='og:site_name' content={SITE.title} />
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:locale' content={ogLocale} />
{altLocales.map(l => <meta property='og:locale:alternate' content={l} />)}
<meta property='og:image' content={imageURL} />
<meta property='og:image:type' content='image/png' />
<meta property='og:image:width' content='1200' />
<meta property='og:image:height' content='630' />
<meta property='og:image:alt' content={title} />
{type === 'article' && publishedTime && (
  <meta property='article:published_time' content={publishedTime.toISOString()} />
)}
{type === 'article' && updatedDate && (
  <meta property='article:modified_time' content={updatedDate.toISOString()} />
)}
{type === 'article' && <meta property='article:author' content={SITE.name} />}

<!-- Twitter -->
<meta name='twitter:card' content='summary_large_image' />
<meta name='twitter:url' content={canonicalURL} />
<meta name='twitter:title' content={title} />
<meta name='twitter:description' content={description} />
<meta name='twitter:image' content={imageURL} />
<meta name='twitter:image:alt' content={title} />

<!-- Structured Data -->
<script type='application/ld+json' is:inline set:html={JSON.stringify(jsonLd)} />
