  cursor: '<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M22.106 5.68L12.5.135a.998.998 0 00-.998 0L1.893 5.68a.84.84 0 00-.419.726v11.186c0 .3.16.577.42.727l9.607 5.547a.999.999 0 00.998 0l9.608-5.547a.84.84 0 00.42-.727V6.407a.84.84 0 00-.42-.726zm-.603 1.176L12.228 22.92c-.063.108-.228.064-.228-.061V12.34a.59.59 0 00-.295-.51l-9.11-5.26c-.107-.062-.063-.228.062-.228h18.55c.264 0 .428.286.296.514z"/></svg>'
}

const openInItems = [
  { key: 'github', label: 'GitHub', href: githubUrl },
  { key: 'chatgpt', label: 'ChatGPT', href: `https://chatgpt.com/?q=${q}` },
  { key: 'claude', label: 'Claude', href: `https://claude.ai/new?q=${q}` },
  { key: 't3', label: 'T3 Chat', href: `https://t3.chat/new?q=${q}` },
  { key: 'copilot', label: 'Copilot', href: `https://github.com/copilot?prompt=${q}` },
  { key: 'cursor', label: 'Cursor', href: `cursor://anysphere.cursor-deeplink/prompt?text=${q}` }
]

const toolBtn =
  'inline-flex items-center gap-1.5 h-8 px-2.5 rounded-lg text-[0.7rem] font-medium uppercase tracking-wider text-gray hover:text-foreground hover:bg-border-light transition-colors duration-200 outline-none focus-visible:ring-2 focus-visible:ring-border border border-transparent cursor-pointer'
const menuItem =
  'flex items-center gap-2.5 w-full px-3 py-2 rounded-lg text-[0.85rem] font-medium text-gray-dark hover:text-foreground hover:bg-border-light transition-colors outline-none focus-visible:ring-2 focus-visible:ring-border cursor-pointer'
---

<div class='blog-actions flex items-center gap-0.5 shrink-0'>
  <!-- Copy MD -->
  <button
    type='button'
    class={`copy-md-btn ${toolBtn}`}
    data-md-url={mdUrl}
    data-label={t('blog.copyMd')}
    data-label-copied={t('blog.copied')}
    aria-label={t('blog.copyMd')}
  >
    <span class='ba-md-icon flex' set:html={ICONS.md} />
    <span class='ba-check-icon hidden text-accent' set:html={ICONS.check} />
    <span class='ba-label'>{t('blog.copyMd')}</span>
  </button>

  <!-- Open in -->
  <div class='open-in-container relative'>
    <button
      type='button'
      class={`open-in-btn ${toolBtn}`}
      aria-label={t('blog.openIn')}
      aria-expanded='false'
      aria-haspopup='true'
    >
      {t('blog.openIn')}
      <span class='ba-chevron flex opacity-70 transition-transform duration-200' set:html={ICONS.chevron} />
    </button>

    <div
      class='open-in-menu absolute right-0 top-[calc(100%+0.5rem)] w-56 p-1.5 rounded-xl bg-surface/95 border border-border backdrop-blur-xl shadow-lg flex flex-col gap-0.5 origin-top-right scale-95 opacity-0 invisible transition-all duration-200 ease-out z-50'
      role='menu'
    >
      <!-- Copy MD Link -->
      <button
        type='button'
        class={`copy-md-link-btn ${menuItem} justify-start`}
        data-md-url={mdUrl}
        data-label={t('blog.copyMdLink')}
        data-label-copied={t('blog.linkCopied')}
        role='menuitem'
      >
        <span class='ba-link-icon flex shrink-0 text-gray' set:html={ICONS.link} />
        <span class='ba-check-icon hidden shrink-0 text-accent' set:html={ICONS.check} />
        <span class='ba-label'>{t('blog.copyMdLink')}</span>
      </button>

      <div class='h-px bg-border my-1'></div>

      {
        openInItems.map(item => (
          <a
            href={item.href}
            target='_blank'
            rel='noopener noreferrer'
            class={`${menuItem} justify-between group`}
            role='menuitem'
          >
            <span class='flex items-center gap-2.5'>
              <span class='flex shrink-0' set:html={ICONS[item.key]} />
              {item.label}
            </span>
            <span class='flex shrink-0 text-gray opacity-0 group-hover:opacity-100 transition-opacity' set:html={ICONS.external} />
          </a>
        ))
      }
    </div>
  </div>
</div>

<style>
  .open-in-container.open .open-in-menu {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
  }

  .open-in-container.open .ba-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
const root = document.querySelector<HTMLElement>('.blog-actions')

if (root) {
  const setupCopy = (btn: HTMLElement, getText: (mdUrl: string) => Promise<string> | string) => {
    let timer: ReturnType<typeof setTimeout> | undefined
    btn.addEventListener('click', async (e) => {
      e.stopPropagation()
      const mdUrl = btn.dataset.mdUrl
      if (!mdUrl) return

      try {
        const text = await getText(mdUrl)
        await navigator.clipboard.writeText(text)

        const label = btn.querySelector<HTMLElement>('.ba-label')
        const defaultIcon = btn.querySelector<HTMLElement>('.ba-md-icon, .ba-link-icon')
        const checkIcon = btn.querySelector<HTMLElement>('.ba-check-icon')
        if (label && btn.dataset.labelCopied) label.textContent = btn.dataset.labelCopied
        defaultIcon?.classList.add('hidden')
        checkIcon?.classList.remove('hidden')

        clearTimeout(timer)
        timer = setTimeout(() => {
          if (label && btn.dataset.label) label.textContent = btn.dataset.label
          defaultIcon?.classList.remove('hidden')
          checkIcon?.classList.add('hidden')
        }, 2000)
      } catch {
      }
    })
  }

  const copyMdBtn = root.querySelector<HTMLElement>('.copy-md-btn')
  if (copyMdBtn) {
    setupCopy(copyMdBtn, async (mdUrl) => {
      const res = await fetch(new URL(mdUrl).pathname)
      return res.text()
    })
  }

  const copyLinkBtn = root.querySelector<HTMLElement>('.copy-md-link-btn')
  if (copyLinkBtn) {
    setupCopy(copyLinkBtn, (mdUrl) => mdUrl)
  }

  const container = root.querySelector<HTMLElement>('.open-in-container')
  const trigger = root.querySelector<HTMLElement>('.open-in-btn')

  if (container && trigger) {
    trigger.addEventListener('click', (e) => {
      e.stopPropagation()
      const isOpen = container.classList.toggle('open')
      trigger.setAttribute('aria-expanded', String(isOpen))
    })

    document.addEventListener('click', (e) => {
      if (!container.contains(e.target as Node)) {
        container.classList.remove('open')
        trigger.setAttribute('aria-expanded', 'false')
      }
    })

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        container.classList.remove('open')
        trigger.setAttribute('aria-expanded', 'false')
      }
    })
  }
}
</script>
