---
import { useTranslations } from '#/i18n/utils'

interface Props {
  mdUrl: string
  githubUrl: string
  lang: 'es' | 'en'
}

const { mdUrl, githubUrl, lang } = Astro.props
const t = useTranslations(lang)

const prompt =
  lang === 'es'
    ? `Lee ${mdUrl} para poder hacerte preguntas sobre este artículo.`
    : `Read ${mdUrl} so I can ask you questions about this article.`
const q = encodeURIComponent(prompt)

const ICONS: Record<string, string> = {
