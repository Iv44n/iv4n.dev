---
import { SITE } from '#/config/site'
import {
  getLangFromUrl,
  useTranslatedPath,
  useTranslations
} from '#/i18n/utils'
import LanguagePicker from '#/components/LanguagePicker.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)

const currentPath = Astro.url.pathname
const normalize = (path: string) => path.replace(/\/$/, '') || '/'
const homePath = translatePath('/')

const navLinks = [
  { href: '/', label: t('nav.home') },
  { href: '/blog/', label: t('nav.writing') },
  { href: '/about/', label: t('nav.about') }
].map(link => {
  const href = translatePath(link.href)
  const isActive =
    href === homePath
      ? normalize(currentPath) === normalize(homePath)
      : normalize(currentPath).startsWith(normalize(href))
  return { ...link, href, isActive }
})
---

<header
  class='fixed top-4 left-1/2 -translate-x-1/2 w-[calc(100%-2rem)] sm:w-full max-w-[640px] z-50'
>
  <!-- Pill Container -->
  <div
    class='flex items-center justify-between p-1.5 pl-5 rounded-full bg-surface/85 border border-border backdrop-blur-xl backdrop-saturate-150 shadow-sm transition-all'
  >
    <!-- Brand -->
    <a
      class='flex items-center gap-2.5 no-underline group outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-full'
      href={homePath}
      aria-label='Home'
    >
      <div
        class='w-2 h-2 rounded-full bg-accent shadow-[0_0_12px_rgba(244,63,94,0.5)] transition-transform duration-300 group-hover:scale-110'
      >
      </div>
      <span class='font-semibold text-foreground text-[0.95rem] tracking-tight'>{SITE.title}
      </span>
    </a>

    <!-- Navigation Area -->
    <div class='flex items-center gap-1'>
      <!-- Desktop Links -->
      <nav class='hidden sm:flex items-center gap-1'>
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              aria-current={link.isActive ? 'page' : undefined}
              class:list={[
                'flex items-center justify-center h-9 px-3.5 rounded-full text-[0.85rem] font-medium transition-all duration-200 outline-none focus-visible:ring-2 focus-visible:ring-border',
                link.isActive
                  ? 'bg-background text-foreground shadow-sm border border-border'
                  : 'text-gray-dark hover:text-foreground hover:bg-border-light border border-transparent'
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- Divider (Desktop) -->
      <div class='hidden sm:block w-[1px] h-4 bg-border mx-1'></div>

      <!-- Language Picker -->
      <LanguagePicker />

      <!-- Theme Toggle -->
      <button
        id='theme-toggle'
        class='flex items-center justify-center h-9 w-9 shrink-0 rounded-full text-gray-dark hover:text-foreground hover:bg-border-light transition-all duration-200 outline-none focus-visible:ring-2 focus-visible:ring-border border border-transparent'
        aria-label='Toggle dark mode'
      >
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='18'
          height='18'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
          class='transition-transform duration-300 hover:rotate-45'
        >
          <path stroke='none' d='M0 0h24v24H0z' fill='none'></path>
          <path d='M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0'></path>
          <path d='M12 3l0 18'></path>
          <path d='M12 9l4.65 -4.65'></path>
          <path d='M12 14.3l7.37 -7.37'></path>
          <path d='M12 19.6l8.85 -8.85'></path>
        </svg>
      </button>

      <!-- Mobile Hamburger Toggle -->
      <button
        id='mobile-menu-toggle'
        class='sm:hidden flex items-center justify-center h-9 w-9 shrink-0 rounded-full text-gray-dark hover:text-foreground hover:bg-border-light transition-all duration-200 outline-none focus-visible:ring-2 focus-visible:ring-border border border-transparent'
        aria-label='Open mobile menu'
      >
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='20'
          height='20'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
        >
          <line x1='4' x2='20' y1='12' y2='12'></line>
          <line x1='4' x2='20' y1='6' y2='6'></line>
          <line x1='4' x2='20' y1='18' y2='18'></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown -->
  <div
    id='mobile-menu'
    class='hidden sm:hidden absolute top-[calc(100%+0.5rem)] left-0 w-full p-2 rounded-2xl bg-surface/95 border border-border backdrop-blur-xl shadow-lg flex-col gap-1 origin-top scale-95 opacity-0 transition-all duration-200 ease-out'
  >
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          aria-current={link.isActive ? 'page' : undefined}
          class:list={[
            'flex items-center justify-center w-full h-11 rounded-xl text-[0.95rem] font-medium transition-all duration-200 outline-none focus-visible:ring-2 focus-visible:ring-border',
            link.isActive
              ? 'bg-background text-foreground shadow-sm border border-border'
              : 'text-gray-dark hover:text-foreground hover:bg-border-light border border-transparent'
          ]}
        >
          {link.label}
        </a>
      ))
    }
  </div>
</header>

<script>
// Setup Dark Mode Toggle
const themeToggle = document.getElementById('theme-toggle')

const handleToggleClick = () => {
  const element = document.documentElement
  element.classList.toggle('dark')

  const isDark = element.classList.contains('dark')
  localStorage.setItem('theme', isDark ? 'dark' : 'light')
}

themeToggle?.addEventListener('click', handleToggleClick)

// Setup Mobile Menu Toggle
const mobileToggle = document.getElementById('mobile-menu-toggle')
const mobileMenu = document.getElementById('mobile-menu')

if (mobileToggle && mobileMenu) {
  mobileToggle.addEventListener('click', () => {
    const isHidden = mobileMenu.classList.contains('hidden')

    if (isHidden) {
      mobileMenu.classList.remove('hidden')
      mobileMenu.classList.add('flex')
      setTimeout(() => {
        mobileMenu.classList.remove('scale-95', 'opacity-0')
        mobileMenu.classList.add('scale-100', 'opacity-100')
      }, 10)
    } else {
      mobileMenu.classList.remove('scale-100', 'opacity-100')
      mobileMenu.classList.add('scale-95', 'opacity-0')
      setTimeout(() => {
        mobileMenu.classList.add('hidden')
        mobileMenu.classList.remove('flex')
      }, 200)
    }
  })
}
</script>
